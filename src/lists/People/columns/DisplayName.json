      },
      "children": [
        {
          "elmType": "span",
          "style": {
            "cursor": "pointer",
            "whitespace": "collapse",
            "user-select": "text",
            "padding-left": "4px",
            "overflow": "hidden",
            "text-overflow": "ellipsis",
            "min-width": "1480px",
            "text-align": "left",
            "text-decoration": "=if(indexOf([$Active]+'~','~')<1 || [$Active], 'inherit', 'line-through')",
            "color": "=if(indexOf([$Active]+'~','~')<1 || [$Active], 'inherit', 'gray')"
          },
          "txtContent": "=if([$Title]=='', [$UniqName], [$DisplayName]) + ' '",
