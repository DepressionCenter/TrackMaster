        "text-align": "right",
        "margin-left": "auto"
      },
      "children": [
        {
          "elmType": "a",
          "attributes": {
            "href": "=if(indexOf([$Email]+'~','~')>1, 'mailto:' + [$Email], if(length([$TeamsAccount])>0, if(indexOf([$TeamsAccount.email]+'~','~')>1, 'mailto:' + [$TeamsAccount.email], if( indexOf([$UniqName]+'~','@')>0, 'mailto:' + [$UniqName], if(indexOf([$UniqName]+'~','~')>0, 'mailto:' + [$UniqName] + '@umich.edu', ''))), if(indexOf([$UniqName]+'~','@')>0, 'mailto:' + [$UniqName], if(indexOf([$UniqName]+'~','~')>0, 'mailto:' + [$UniqName] + '@umich.edu', ''))))",
            "target": "_blank"
