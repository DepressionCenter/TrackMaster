            {
              "elmType": "div",
              "attributes": {
                "iconName": "=if(indexOf([$Email]+'~','~')<1 && length([$TeamsAccount])<1, 'MailUndelivered', 'Mail')",
                "class": "ms-fontSize-16 ms-fontWeight-regular ms-fontColor-themePrimary",
                "title": "=if(indexOf([$Email]+'~','~')<1, if(length([$TeamsAccount])<1, 'Email not available in this view.', [$TeamsAccount.email]) , [$Email])"
              },
              "style": {
                "color": "=if(indexOf([$Email]+'~','~')<1 && length([$TeamsAccount])<1, 'gray', 'inherit')"
              }
