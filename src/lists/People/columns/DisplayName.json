            "width": "36px",
            "min-width": "32px",
            "height": "36px",
            "overflow": "hidden",
            "border-radius": "50%",
            "margin": "2px",
            "padding-right": "2px"
          },
          "attributes": {
            "src": "=if(lastIndexOf([$ProfilePictureURL]+'~','~')>2, [$ProfilePictureURL], if(length([$TeamsAccount])==0, @currentWeb + '/_layouts/15/userphoto.aspx?size=S', @currentWeb + '/_layouts/15/userphoto.aspx?size=M&accountName=' + [$TeamsAccount.email]))",
            "title": "=if(length([$TeamsAccount])==0, if([$Title]=='', [$UniqName], [$Title]) + if([$Job_x0020_Rank]=='', if([$JobTitle]=='', '', ' | '+[$JobTitle]), ' | '+[$Job_x0020_Rank]) + if([$Appointing_x0020_Department_x003]=='', if([$Department]=='', '', ' | '+[$Department]), ' | '+ [$Appointing_x0020_Department_x003]), '')"
          }
        }
